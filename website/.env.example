# === LLM-Konfiguration ===
# Option A: Lokales Ollama (Standard)
OLLAMA_URL=http://host.docker.internal:11434

# Option B: Mistral API (Cloud, EU-Server Paris — DSGVO-konform)
# Wenn MISTRAL_API_KEY gesetzt ist, wird die Cloud-API statt Ollama verwendet.
# Beantragen: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=
# Modell (Standard: mistral-small-latest, Alternativen: mistral-medium-latest, mistral-large-latest)
MISTRAL_MODEL=mistral-small-latest

# PubMed API-Key (kostenlos, erhöht Rate-Limit)
# Beantragen: https://ncbiinsights.ncbi.nlm.nih.gov/2017/11/02/new-api-keys-for-the-e-utilities/
PUBMED_API_KEY=
# E-Mail für PubMed (von NCBI gefordert bei automatisierten Abfragen)
PUBMED_EMAIL=

# Google Fact Check Tools API (kostenlos, für ClaimReview-Suche)
# Beantragen: https://console.cloud.google.com/apis/library/factchecktools.googleapis.com
GOOGLE_FACTCHECK_API_KEY=

# Copernicus Climate Data Store (Katalog funktioniert auch ohne Key)
# Beantragen: https://cds.climate.copernicus.eu/how-to-api
CDS_API_KEY=

# Impressum (Pflicht wenn öffentlich zugänglich, § 5 ECG)
# Jeder Betreiber muss seine eigenen Daten eintragen
IMPRESSUM_NAME=
IMPRESSUM_EMAIL=
IMPRESSUM_LOCATION=
